PORT=4000
NODE_ENV=development
APP_ENV=development
APP_BASE_URL=http://localhost:4000
PASSWORD_RESET_REDIRECT_URL=nlbb://reset-password
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5181,http://127.0.0.1:5181
TRUST_PROXY=
EMAIL_FROM="NLBB <info@nlbb.co.ke>"
EMAIL_REPLY_TO=info@nlbb.co.ke

# Preferred email provider
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Legacy SMTP fallback (optional)
SMTP_HOST=mail.your-domain.co.ke
SMTP_PORT=465
SMTP_FALLBACK_PORT=587
SMTP_SECURE=true
SMTP_REQUIRE_TLS=false
SMTP_IGNORE_TLS=false
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=20000
SMTP_USER=no-reply@nlbb.co.ke
SMTP_PASSWORD=your-smtp-password
PAYMENTS_ENABLED=true
MPESA_ENABLED=true

# Supabase - get these from your project's Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-or-publishable-key
SUPABASE_USER_AVATAR_BUCKET=user-avatars
SUPABASE_PROVIDER_AVATAR_BUCKET=provider-avatars
SUPABASE_PROVIDER_COVER_BUCKET=provider-covers
SUPABASE_PROVIDER_GALLERY_BUCKET=provider-gallery

# Supabase PostgreSQL - Settings > Database > Connect > Session pooler
# Copy the exact URI from the dashboard. Session pooler is the safer default on IPv4-only networks.
DATABASE_URL=postgresql://postgres.your-project-ref:[YOUR-PASSWORD]@aws-0-your-region.pooler.supabase.com:5432/postgres
DATABASE_POOL_MAX=10

# M-Pesa Daraja
MPESA_SIMULATE=true
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=http://localhost:4000/api/payments/mpesa/callback
MPESA_CALLBACK_SECRET=
MPESA_INITIATOR_NAME=
MPESA_SECURITY_CREDENTIAL=

# Optional web-admin API key bypass (for internal trusted proxy)
ADMIN_API_KEY=
ADMIN_API_KEY_ENABLED=true
REQUIRE_ACTIVE_USER=true
