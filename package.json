{
  "name": "nlbb-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Backend API for NLBB beauty marketplace",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:local": "powershell -ExecutionPolicy Bypass -File ./scripts/start-local-dev.ps1",
    "mpesa:tunnel": "powershell -ExecutionPolicy Bypass -File ./scripts/start-mpesa-tunnel.ps1",
    "db:start:local": "powershell -ExecutionPolicy Bypass -File ./scripts/start-local-dev.ps1 -SkipBackend",
    "db:stop:local": "powershell -ExecutionPolicy Bypass -File ./scripts/stop-local-db.ps1",
    "db:status:local": "powershell -ExecutionPolicy Bypass -File ./scripts/status-local-db.ps1",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "seed": "tsx src/scripts/seed.ts",
    "seed:yes": "tsx src/scripts/seed.ts --yes",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.0",
    "@types/pg": "^8.20.0",
    "axios": "^1.8.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "pg": "^8.20.0",
    "postgres": "^3.4.9",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.13.9",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=18"
  }
}
